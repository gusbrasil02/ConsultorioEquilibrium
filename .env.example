PORT=3000

# Supabase (use SEMPRE a chave service_role, nunca a anon)
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui

# Anthropic (explicações da IA na tela do paciente)
ANTHROPIC_API_KEY=sua_chave_aqui

# URL base usada para gerar os QR Codes do formulário.
# Em produção use o domínio público; em rede local, o IP (ex: http://192.168.1.100:3000)
BASE_URL=https://consultorioequilibrium.datawavebr.com

# Segredo para assinar o cookie de login do painel (item 4).
# Gere um valor aleatório longo e mantenha fixo — se mudar, todos os logins caem.
JWT_SECRET=troque_por_um_valor_aleatorio_longo

# Em produção (HTTPS) deixe como 'production' para o cookie de login ser Secure.
NODE_ENV=production
